{
  "manifest_version": "0.3",
  "name": "miro-developer-platform-pp-mcp",
  "display_name": "Miro Developer Platform",
  "version": "4.2.2",
  "description": "Miro Developer Platform API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/miro-developer-platform-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/miro-developer-platform-pp-mcp",
      "args": [],
      "env": {
        "MIRO_ACCESS_TOKEN": "${user_config.miro_access_token}"
      }
    }
  },
  "user_config": {
    "miro_access_token": {
      "type": "string",
      "title": "MIRO_ACCESS_TOKEN",
      "description": "Sets MIRO_ACCESS_TOKEN for the Miro Developer Platform MCP server.",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
